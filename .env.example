# postgresql+asyncpg:// says to SQLAlchemy use asyncpg.
# Format: dialect+driver://user:pass@host:port/dbname
 
# For Docker Compose use: @db:5432 and redis://redis:6379/0
# For local run use: @localhost:5432 and redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/deribit_db
REDIS_URL=redis://redis:6379/0
 
DERIBIT_BASE_URL=https://www.deribit.com/api/v2
# Base URL Deribit API.